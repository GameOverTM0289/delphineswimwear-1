# ============================================================================
#  Delphine Swimwear — environment variables
#  Copy this file to `.env` for local dev, and set the same keys in your
#  Vercel project (Settings → Environment Variables) for production.
#  NEVER commit a real .env to git.
# ============================================================================

# ───────── Database (Postgres: Neon / Supabase / Vercel Postgres) ─────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ───────── Site ─────────
# Absolute https URL of the deployed site. REQUIRED for POK — the payment
# redirect + webhook URLs are built from it. No trailing slash, no stray quotes.
NEXT_PUBLIC_SITE_URL="https://delphineswimwear.com"

# ───────── Admin ─────────
ADMIN_EMAIL="admin@delphineswimwear.com"
# Generate with `npm run admin:hash` and paste the output here.
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_SECRET="generate-a-long-random-string"
ADMIN_NOTIFICATION_EMAIL="info@delphineswimwear.com"

# ───────── Email (Resend) ─────────
RESEND_API_KEY=""
EMAIL_FROM="contact@delphineswimwear.com"
EMAIL_FROM_NAME="Delphine"

# ───────── Rate limiting (Upstash Redis) ─────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ───────── Analytics & error tracking (optional) ─────────
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_SENTRY_DSN=""

# ============================================================================
#  POK PAYMENT (pokpay.io)
# ============================================================================
# From the POK Business dashboard → E-payments → API Keys → Create.
# Creating a key shows the keySecret ONCE — copy it immediately.
#
#   POK_KEY_ID       = the "keyId" of your API key
#   POK_KEY_SECRET   = the "keySecret" of your API key (keep secret!)
#   POK_MERCHANT_ID  = your merchant id (Dashboard / account)
#   POK_ENV          = "production" (default) or "staging" for test
#
# Leave these blank to run the store in "no-payment" mode: orders are saved
# and the buyer lands on the order page with ?pending=1 (useful before go-live).
POK_KEY_ID=""
POK_KEY_SECRET=""
POK_MERCHANT_ID=""
POK_ENV="production"
